	<string id="ui_st_move_items">
		<text>To move or purchase multiple items at a time, hold left CTRL or left ALT or left SHIFT + Double-click the LMB on the desired item</text>
	</string>
	
	<string id="st_new_game_msg">
		<text>Before starting the game, it is strongly recommended to read the "FAQ" and "Features, tips and drawbacks" files (in the Readme ENG folder), as well as the "Guide" in the PDA. Have a good game!</text>
	</string>	
	
	<string id="ui_st_unbind">
		<text>To reset a particular key, move the cursor over it and press %c[255,216,186,140]RMB</text>
	</string>	
	
	<string id="ui_st_defaults">
		<text>To reset all settings, delete %c[255,216,186,140]user.ltx %c[default]file from the %c[255,216,186,140]datafiles %c[default]folder.\n \nThere are also tooltips for most options (hover your cursor over the option name)</text>
	</string>		
	
	<string id="ui_st_hint_opt">
		<text>Some options in this section, will only become available after the gameplay has started</text>
	</string>	
	
	<string id="ui_mm_cryray_static_geom">
		<text>Optimization of stat. objects</text>
	</string>
	
	<string id="ui_mm_cryray_static_geom_hint">
		<text>Responsible for the range of visibility of static (stationary) objects. The higher the value, the smaller the range of visibility.\n \nDefault: %c[255,216,186,140]"1"\n \n%c[default]Effect on FPS: %c[ui_green]low</text>
	</string>		
	
	<string id="ui_mm_cryray_dynamic_geom">
		<text>Optimization of dyn. objects</text>
	</string>	
	
	<string id="ui_mm_cryray_dynamic_geom_hint">
		<text>Responsible for the range of visibility of dynamic (moving) objects. The higher the value, the smaller the range of visibility.\n \nDefault: %c[255,216,186,140]"1"\n \n%c[default]Effect on FPS: %c[ui_green]low</text>
	</string>		
	
	<string id="ui_mm_cryray_graphics_opt_3">
		<text>Distant Texture Quality</text>
	</string>
	
	<string id="ui_mm_cryray_graphics_opt_3_hint">
		<text>Responsible for the quality and range of texture rendering at a distance.\n \nDefault: %c[255,216,186,140]"62"\n \n%c[default]Effect on FPS: %c[ui_green]very low</text>
	</string>	
	
	<string id="ui_mm_cryray_graphics_opt_5">
		<text>Anisotropic Filtering</text>
	</string>
	
	<string id="ui_mm_cryray_graphics_opt_5_hint">
		<text>It is a technology that improves the display of textures when they are placed in the field of view at an oblique angle or at a distance.\n \nDefault: %c[255,216,186,140]"8"\n \n%c[default]Effect on FPS: %c[ui_green]low</text>
	</string>		
	
	<string id="ui_mm_cryray_graphics_opt_9">
		<text>Anti-Aliasing Type</text>
	</string>
	
	<string id="ui_mm_cryray_graphics_opt_9_hint">
		<text>It is a technology that reduces «jagged» edges (aliasing) on objects, making lines and contours look smoother and more realistic.\n \nDefault: %c[255,216,186,140]"Disabled"\n \n%c[default]Effect on FPS: %c[ui_orange]high</text>
	</string>		
	
	<string id="ui_mm_cryray_graphics_opt_20">
		<text>Sun Rays</text>
	</string>
	
	<string id="ui_mm_cryray_graphics_opt_20_hint">
		<text>This option is responsible for displaying volumetric rays from sunlight.\n \nDefault: %c[255,216,186,140]"Volumetric"\n \n%c[default]Effect on FPS: %c[ui_yellow]medium</text>
	</string>	
	
	<string id="ui_mm_cryray_graphics_opt_24">
		<text>FPS Counter</text>
	</string>
	
	<string id="ui_mm_cryray_graphics_opt_24_hint">
		<text>Display the FPS counter in the lower left corner of the screen.\n \nDefault: %c[255,216,186,140]"Enabled"</text>
	</string>		
	
	<string id="ui_mm_cryray_graphics_opt_33">
		<text>Player Shadow</text>
	</string>
	
	<string id="ui_mm_cryray_graphics_opt_33_hint">
		<text>This option is responsible for displaying the player's shadow.\n \nDefault: %c[255,216,186,140]"Disabled"\n \n%c[default]Effect on FPS: %c[ui_green]very low</text>
	</string>	
	
	<string id="ui_mm_cryray_graphics_opt_34">
		<text>Grass Shadow</text>
	</string>
	
	<string id="ui_mm_cryray_graphics_opt_34_hint">
		<text>This option is responsible for displaying grass shadows.\n \nDefault: %c[255,216,186,140]"Disabled"\n \n%c[default]Effect on FPS: %c[ui_green]low</text>
	</string>
	
	<string id="ui_mm_cryray_graphics_opt_101">
		<text>DoF in Scope</text>
	</string>
	
	<string id="ui_mm_cryray_graphics_opt_101_hint">
		<text>Responsible for blurring the image while aiming.\n \nDefault: %c[255,216,186,140]"Disabled"</text>
	</string>	
	
	<string id="ui_mm_cryray_graphics_opt_102">
		<text>DoF in Reload</text>
	</string>
	
	<string id="ui_mm_cryray_graphics_opt_102_hint">
		<text>Responsible for blurring the image during reloading.\n \nDefault: %c[255,216,186,140]"Enabled"</text>
	</string>		
	
	<string id="ui_mm_cryray_graphics_opt_103">
		<text>DoF for Weather</text>
	</string>
	
	<string id="ui_mm_cryray_graphics_opt_103_hint">
		<text>Responsible for blurring the image on the horizon.\n \nDefault: %c[255,216,186,140]"Enabled"</text>
	</string>	
	
	<string id="ui_mm_cryray_graphics_opt_104">
		<text>Vertical Sync</text>
	</string>
	
	<string id="ui_mm_cryray_graphics_opt_104_hint">
		<text>This is a technology designed to eliminate image tearing. It synchronizes the refresh rate of the monitor image with the frame rate of the game.\n \nDefault: %c[255,216,186,140]"Disabled"</text>
	</string>	
	
	<string id="ui_mm_cryray_dof_animator">
		<text>DoF for Items</text>
	</string>

	<string id="ui_mm_cryray_dof_animator_hint">
		<text>Responsible for blurring the image while playing animations of items (medicine, provisions, etc.).\n \nDefault: %c[255,216,186,140]"Enabled"</text>
	</string>	
	
	<string id="ui_mm_cryray_3d_scopes">
		<text>PiP Scopes</text>
	</string>
	
	<string id="ui_mm_cryray_3d_scopes_hint">
		<text>Enables display of PiP (picture in picture) scopes.\n \nDefault: %c[255,216,186,140]"Enabled"\n \n%c[default]Effect on FPS: %c[ui_red]very high</text>
	</string>				
	
	<string id="ui_mm_cryray_mipbias">
		<text>Texture Sharpness</text>
	</string>
	
	<string id="ui_mm_cryray_mipbias_hint">
		<text>Affects the level of detail and clarity of textures applied to 3D-models and surfaces in the game world.\n \nDefault: %c[255,216,186,140]"0"\n \n%c[default]Effect on FPS: %c[ui_green]very low</text>
	</string>

	<string id="ui_mm_cryray_mask_hud">
		<text>Gas mask shader</text>
	</string>	

	<string id="ui_mm_cryray_mask_hud_hint">
		<text>Responsible for displaying the "fogged edges" and raindrop effect when wearing helmets or suits with a built-in helmet.\n \nDefault: %c[255,216,186,140]"Enabled"\n \n%c[default]Effect on FPS: %c[ui_yellow]medium</text>
	</string>		
	
	<string id="ui_mm_need_restart_level">
